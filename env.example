{% extends 'base.html' %}
{% block title %}비밀번호 재설정 — Paper Shelf{% endblock %}
{% block content %}
<section class="auth-card">
  <p class="eyebrow">RESET PASSWORD</p>
  <h1>비밀번호 재설정</h1>
  <p class="muted">가입 이메일을 입력하면 새 비밀번호를 설정할 수 있는 일회용 링크를 보내드립니다.</p>
  <form method="post" class="stack-form">
    {% csrf_token %}
    {{ form.as_p }}
    <button class="button primary" type="submit">재설정 링크 받기</button>
  </form>
  <p class="muted auth-back"><a href="{% url 'account_recovery' %}">계정 복구로 돌아가기</a></p>
</section>
{% endblock %}
